{"blocks":[{"type":"codeTool","data":{"codeData":{"value":"### Utility functions","pinCode":false,"dname":"e526fcda-46f7-4a19-9c20-560e7cde320d","codeMode":"markdown"}}},{"type":"codeTool","data":{"codeData":{"value":"propagateCompanyName = ()=>\n{\n//   Add Company:id => Company:company\n  gxr.nodes(':Company').forEach(c=>{\n    c.properties.company = c.properties.id\n  })\n//   Add Company:id => Market/Risk/Competitor:company\n  let myedges = gxr.edges().array.filter(e=>['Market', 'Risk', 'Competitor'].includes(e.target.category))\n  myedges.forEach(e=>{\n    e.target.properties.company = e.source.properties.id\n  })\n\n}","pinCode":true,"dname":"96af62eb-84b3-4ff2-814d-ccc6af114568","codeMode":"javascript2"}}},{"type":"codeTool","data":{"codeData":{"value":"","pinCode":true,"dname":"438e5a6f-4e03-4386-a227-0d7a1026ba8c","codeMode":"javascript2"}}},{"type":"codeTool","data":{"codeData":{"value":"myedges[1].source.properties","pinCode":true,"dname":"cb676e21-7baf-48ec-b9ba-aadaed712fce","codeMode":"javascript2"}}}],"version":"2.19.1"}