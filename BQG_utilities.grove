{"blocks":[{"type":"codeTool","data":{"codeData":{"value":"md`# Untitled`","pinCode":true,"dname":"fa2fec34-0c55-4aae-9c96-76326f520eff","codeMode":"javascript2"}}},{"type":"codeTool","data":{"codeData":{"value":"// {\n// \tlet query=`MATCH (s:Site) return s.name limit 5`\n//     return BQGQueryToTable(query)\n// }","pinCode":true,"dname":"0fd72d03-b4f4-4b5f-a142-04cf71fd1f15","codeMode":"javascript2"}}},{"type":"codeTool","data":{"codeData":{"value":"BQGQueryToTable = async (query) =>{\n  let res = await gxr.query(query, {saveToGraph : false})\n  return parseQueryTable(res.data)\n}","pinCode":true,"dname":"1fdb36d0-59c1-44ab-b261-57207bcbb792","codeMode":"javascript2"}}},{"type":"codeTool","data":{"codeData":{"value":"parseQueryTable = (data)=>{  if(data.length==0) return []\n  else{\n    const [header, ...rows]=data;\n    const jsonArray = rows.map(row => {\n      return Object.fromEntries(header.map((key, index) => [key, row[index]]));\n});\n    return jsonArray\n  }\n}","pinCode":false,"dname":"0bcd5c46-ac38-4ed7-a675-1f8dd5af76bd","codeMode":"javascript2"}}}],"version":"2.19.1"}