{"blocks":[{"type":"codeTool","data":{"codeData":{"value":"md `<div style=\"display: flex; justify-content: space-between; font-size: 1.2em;\">\n  <a>${Link(\"EntityAnalysis\", \"Back to Analysis\")} </a>\n</div>`","pinCode":false,"dname":"e80cb4a2-9f4f-496b-bd92-03a1798be82d","codeMode":"javascript2"}}},{"type":"codeTool","data":{"codeData":{"value":"initialKey = localStorage.getItem(\"openai_api_key\") ?? \"\"","pinCode":false,"dname":"09e3243f-66af-4667-84c9-0fe8dcb36aa1","codeMode":"javascript2","hide":true}}},{"type":"codeTool","data":{"codeData":{"value":"// viewof showKey = Inputs.toggle({label: \"Show key\", value: false})","pinCode":false,"dname":"855ae1a1-9411-43f4-b1a8-7886e868c1b4","codeMode":"javascript2","hide":true}}},{"type":"codeTool","data":{"codeData":{"value":"// 3) Masked input with live binding (re-renders when showKey changes)\nviewof openAIKey = {\n  const wrapper = html`<div style=\"display:flex; gap:8px; align-items:center;\"></div>`;\n  const input = html`<input placeholder=\"sk-...\" style=\"width:360px; padding:6px 8px;\">`;\n//   input.type = showKey ? \"text\" : \"password\";\n  input.type = \"password\"\n  input.value = initialKey;\n\n  // expose the value to Observable and notify on change\n  wrapper.value = input.value;\n  input.addEventListener(\"input\", () => {\n    wrapper.value = input.value;\n    wrapper.dispatchEvent(new CustomEvent(\"input\"));\n  });\n    // small validity hint (client-side only; don’t overfit the regex)\n  const hint = html`<span style=\"font:12px/1.2 system-ui;\"></span>`;\n  const validate = v => v.startsWith(\"sk-\") && v.length > 20;\n  const updateHint = () => hint.textContent = input.value === \"\" ? \"\" : (validate(input.value) ? \"Looks OK ✅\" : \"Doesn’t look like an OpenAI key\");\n  input.addEventListener(\"input\", updateHint);\n  updateHint();\n\n  wrapper.append(input, hint);\n  return wrapper;\n}","pinCode":false,"dname":"798893b9-1829-4984-ab89-b0053d42ed7a","codeMode":"javascript2"}}},{"type":"codeTool","data":{"codeData":{"value":"// 4) Buttons to save/forget the key (local to the user’s browser)\nviewof saveKey = Inputs.button(\"Save key (localStorage)\", {reduce: ()=>{\n    localStorage.setItem(\"openai_api_key\", openAIKey);\n    \"✅ Saved locally\"\n}})","pinCode":false,"dname":"a602944b-54b9-4655-954b-37a932b825a7","codeMode":"javascript2"}}},{"type":"codeTool","data":{"codeData":{"value":"viewof forgetKey = Inputs.button(\"Forget key\", {reduce: ()=>\n{\n    localStorage.removeItem(\"openai_api_key\");\n    // also clear the live field\n    const el = Generators.input(openAIKey);\n    el.value = \"\";\n    el.dispatchEvent(new CustomEvent(\"input\"));\n    \"🗑️ Removed from localStorage\"\n}})","pinCode":false,"dname":"c27e919e-0f99-4592-806b-8b336054a5f0","codeMode":"javascript2"}}},{"type":"codeTool","data":{"codeData":{"value":"// 5) A tiny helper you can import in other cells\nfunction getOpenAIKey() {\n  const k = openAIKey?.trim?.() ?? \"\";\n  if (!k) throw new Error(\"Missing OpenAI API key. Please enter yours above.\");\n  return k;\n}","pinCode":false,"dname":"76a1e98a-2cfa-40c8-a049-751e1829b4f2","codeMode":"javascript2","hide":true}}},{"type":"codeTool","data":{"codeData":{"value":"// getOpenAIKey()","pinCode":false,"dname":"f2b519d2-6f07-4c5b-b25b-afb12f77523a","codeMode":"javascript2","hide":true}}}],"version":"2.19.1"}